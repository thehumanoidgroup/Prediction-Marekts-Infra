# Copy to .env and adjust. docker-compose reads this file automatically.

# --- Backend (FastAPI) ---
PP_ENVIRONMENT=development
PP_SECRET_KEY=change-me-in-production
PP_DATABASE_URL=postgresql+asyncpg://proppredict:proppredict@postgres:5432/proppredict
PP_REDIS_URL=redis://redis:6379/0
PP_CORS_ORIGINS=["http://localhost:3000"]

# --- Polymarket CLOB (optional — read-only works with defaults) ---
PP_POLYMARKET_HOST=https://clob.polymarket.com
PP_POLYMARKET_CHAIN_ID=137
# PP_POLYMARKET_PRIVATE_KEY=
# PP_POLYMARKET_API_KEY=
# PP_POLYMARKET_API_SECRET=
# PP_POLYMARKET_API_PASSPHRASE=
PP_POLYMARKET_CACHE_TTL_SECONDS=300
PP_POLYMARKET_LIST_CACHE_TTL_SECONDS=600
PP_POLYMARKET_MAX_FETCH_PAGES=10
PP_POLYMARKET_REQUEST_TIMEOUT_SECONDS=30
PP_POLYMARKET_RATE_LIMIT_PER_MINUTE=60
PP_POLYMARKET_RATE_LIMIT_BURST=10
PP_POLYMARKET_MAX_RETRIES=3
PP_POLYMARKET_RETRY_BACKOFF_SECONDS=0.5

# --- Kalshi Trading API (optional — public market data works with defaults) ---
PP_KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
PP_KALSHI_DEMO_BASE_URL=https://demo-api.kalshi.co/trade-api/v2
# PP_KALSHI_USE_DEMO=false
# PP_KALSHI_API_KEY=
# PP_KALSHI_API_SECRET=
# Or without PP_ prefix:
# KALSHI_API_KEY=
# KALSHI_API_SECRET=
PP_KALSHI_CACHE_TTL_SECONDS=300
PP_KALSHI_LIST_CACHE_TTL_SECONDS=600
PP_KALSHI_PRICE_CACHE_TTL_SECONDS=30
PP_KALSHI_MAX_FETCH_PAGES=10
PP_KALSHI_REQUEST_TIMEOUT_SECONDS=30
PP_KALSHI_RATE_LIMIT_PER_MINUTE=60
PP_KALSHI_MAX_RETRIES=3
PP_KALSHI_RETRY_BACKOFF_SECONDS=0.5

# --- Database (docker-compose postgres service) ---
POSTGRES_USER=proppredict
POSTGRES_PASSWORD=proppredict
POSTGRES_DB=proppredict

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# --- Sakana Fugu (deployment review assistant — optional) ---
# Create at https://console.sakana.ai/get-started
# SAKANA_API_KEY=
