# PropPredict — environment variables
# Copy to .env.local for local development.

# --- Core ---
NODE_ENV=development
SECRET_KEY=change-me-in-production
# Optional dedicated key for encrypting TraderDemoAccount.login_credentials
# CREDENTIALS_ENCRYPTION_KEY=
# Public app URL for magic login links
# APP_URL=https://your-app.vercel.app

# --- Database (PostgreSQL — required for auth & tenant persistence) ---
# Vercel Postgres, Neon, or Supabase connection string
DATABASE_URL=postgresql://user:password@localhost:5432/proppredict

# --- Polymarket CLOB (optional — read-only works with defaults) ---
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
# POLYMARKET_PRIVATE_KEY=
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=
POLYMARKET_CACHE_TTL_SECONDS=300
# Keep low on Vercel to avoid serverless timeouts (sampling-markets pages).
POLYMARKET_MAX_FETCH_PAGES=2
# Cap live-events cards pulled per source (internal / polymarket / kalshi).
LIVE_EVENTS_PER_SOURCE=24

# --- Kalshi Trading API (optional — public listings work without keys) ---
PP_KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
PP_KALSHI_DEMO_BASE_URL=https://demo-api.kalshi.co/trade-api/v2
# PP_KALSHI_USE_DEMO=false
# PP_KALSHI_API_KEY=
# PP_KALSHI_API_SECRET=
# KALSHI_API_KEY=
# KALSHI_API_SECRET=
KALSHI_CACHE_TTL_SECONDS=60
PP_KALSHI_CACHE_TTL_SECONDS=300
PP_KALSHI_LIST_CACHE_TTL_SECONDS=600
PP_KALSHI_PRICE_CACHE_TTL_SECONDS=30

# --- Alpaca Market Data (IEX free tier — S&P 500 stock data for MVP) ---
# Docs: https://alpaca.markets/docs/
#       https://alpaca.markets/docs/api-references/market-data-api/
#       https://alpaca.markets/docs/api-references/market-data-api/stock-pricing-data/realtime/
# Use paper trading keys from the Alpaca dashboard for the MVP.
# Replace with Polygon.io when scaling beyond IEX / free-tier limits.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Optional (also accepted as PP_ALPACA_*):
# PP_ALPACA_DATA_BASE_URL=https://data.alpaca.markets/v2
# PP_ALPACA_IEX_STREAM_URL=wss://stream.data.alpaca.markets/v2/iex
# PP_ALPACA_FEED=iex
# PP_ALPACA_RATE_LIMIT_PER_MINUTE=180
# PP_ALPACA_WS_MAX_SYMBOLS=30
# S&P 500 dynamic market generator (daily LMSR + LiveEvent upsert).
# Alpaca used for MVP. Will switch to Polygon for scale.
# PP_SP500_GENERATOR_ENABLED=true
# PP_SP500_GENERATOR_INTERVAL_SECONDS=86400
# PP_SP500_GENERATOR_TICKER_LIMIT=50
# PP_SP500_GENERATOR_RUN_ON_STARTUP=false
# Optional browser → FastAPI markets WebSocket (stock_quote + price_update).
# Alpaca WebSocket for MVP. Polygon WebSocket ready for later scaling.
# NEXT_PUBLIC_MARKETS_WS_URL=ws://localhost:8000

# --- Trader login links (provisioning emails) ---
PP_TRADER_LOGIN_BASE_URL=http://localhost:3000/login

# --- Email (Resend — provisioning notifications) ---
# https://resend.com/api-keys
# RESEND_API_KEY=re_...
# EMAIL_FROM=PropPredict <notifications@yourdomain.com>
# SUPPORT_EMAIL=support@yourdomain.com
# PROVISIONING_EMAILS_ENABLED=true

# --- Provisioning queue (async background processing) ---
# PROVISIONING_ASYNC=true
# PROVISIONING_QUEUE=database
# PROVISIONING_WORKER_SECRET=change-me-worker-secret

# --- Provisioning webhook rate limit ---
# PROVISIONING_WEBHOOK_RATE_LIMIT=60
# PROVISIONING_WEBHOOK_RATE_WINDOW_MS=60000
