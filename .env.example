# PropPredict — environment variables
# Copy to .env.local for local development.

# --- Core ---
NODE_ENV=development
SECRET_KEY=change-me-in-production
# Optional dedicated key for encrypting TraderDemoAccount.login_credentials
# CREDENTIALS_ENCRYPTION_KEY=

# --- Database (PostgreSQL — required for auth & tenant persistence) ---
# Vercel Postgres, Neon, or Supabase connection string
DATABASE_URL=postgresql://user:password@localhost:5432/proppredict

# --- Polymarket CLOB (optional — read-only works with defaults) ---
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
# POLYMARKET_PRIVATE_KEY=
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=
POLYMARKET_CACHE_TTL_SECONDS=300
POLYMARKET_MAX_FETCH_PAGES=10
